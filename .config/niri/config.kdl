// Main Niri Configuration
// Split into separate files for better organization


include "layout.kdl"
include "startup.kdl"
include "window-rules.kdl"
include "keybinds.kdl"

prefer-no-csd
hotkey-overlay {
    // Uncomment this line to disable the "Important Hotkeys" pop-up at startup.
    // skip-at-startup
}

// Uncomment this line to ask the clients to omit their client-side decorations if possible.
// prefer-no-csd

// Screenshot path
screenshot-path "~/Pictures/Screenshots/Screenshot from %Y-%m-%d %H-%M-%S.png"

// Animation settings
animations {
    // Uncomment to turn off all animations.
    // off

    // Slow down all animations by this factor. Values below 1 speed them up instead.
    slowdown 0.4
}

// Input device configuration
input {
    keyboard {
        xkb {
            // You can set rules, model, layout, variant and options.
            // For more information, see xkeyboard-config(7).
        }

        // Enable numlock on startup
        numlock
    }

    touchpad {
        tap
        natural-scroll
    }

    mouse {
        // off
        // natural-scroll
        accel-speed 0
        accel-profile "flat"
    }

    trackpoint {
        // off
        // natural-scroll
        // accel-speed 0.2
    }

    // Uncomment to make mouse warp to center of newly focused windows
    // warp-mouse-to-focus

    //Focus follows mouse
    // focus-follows-mouse max-scroll-amount="0%"
}

// Output configuration
// Run `niri msg outputs` to see your actual output names

// Left monitor - 1080p 60Hz (secondary)

// Main monitor - 2K 240Hz (middle/right)
output "DP-1" {
    mode "2560x1440@240"
    position x=0 y=0
    backdrop-color "#181818"
}

// Note: Run `niri msg outputs` to get your actual output names
// They might be different like "HDMI-1", "DisplayPort-0", etc.
