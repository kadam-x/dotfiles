[global]
    monitor = 0
    follow = mouse
    width = 350
    height = 150
    origin = top-right
    offset = 20x20
    scale = 0
    notification_limit = 5

    ### Appearance
    # Matching base00 and base02
    frame_width = 2
    frame_color = "#999999"
    separator_color = "#999999"
    font = Iosevka Term 10
    line_height = 4
    padding = 12
    horizontal_padding = 12
    text_icon_padding = 10
    
    # Progress Bar (Matching base0B)
    progress_bar = true
    progress_bar_height = 8
    progress_bar_frame_width = 1
    progress_bar_min_width = 150
    progress_bar_max_width = 300
    progress_bar_corner_radius = 0

    ### Icons
    icon_position = left
    min_icon_size = 32
    max_icon_size = 64

    ### Text Formatting
    # Using base05 for primary text
    format = "<b>%s</b>\n%b"
    alignment = left
    vertical_alignment = center
    show_age_threshold = 60
    word_wrap = yes
    stack_duplicates = true
    hide_duplicate_count = false

    ### Behavior
    transparency = 0
    idle_threshold = 120
    sticky_history = yes
    history_length = 20
    dmenu = /usr/bin/dmenu -p dunst:
    browser = /usr/bin/xdg-open
    always_run_script = true
    title = Dunst
    class = Dunst

[urgency_low]
    # base01 background, base04 text
    background = "#121212"
    foreground = "#999999"
    timeout = 5

[urgency_normal]
    # base00 background, base05 text
    background = "#000000"
    foreground = "#c1c1c1"
    timeout = 10
    override_pause = false

[urgency_critical]
    # base00 background, Diagnostic Error override foreground
    background = "#000000"
    foreground = "#912222"
    frame_color = "#912222"
    timeout = 0
